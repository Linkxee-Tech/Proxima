# Required for GPT-5.6 structured intent parsing, DAG planning, embeddings, and Codex bridge scripts.
OPENAI_API_KEY=
PROXIMA_OPENAI_MODEL=gpt-5.6
PROXIMA_STORAGE_BACKEND=local
# Set to the Supabase PostgreSQL URI only when PROXIMA_STORAGE_BACKEND=postgres.
PROXIMA_DATABASE_URL=
PROXIMA_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
# Social copy uses Terra; visual campaign assets use OpenAI's image generation endpoint.
PROXIMA_SOCIAL_TEXT_MODEL=gpt-5.6-terra
PROXIMA_IMAGE_MODEL=gpt-image-2
PROXIMA_UPLOAD_MAX_BYTES=10485760

# Set to a long random value to require user registration/login and secure WebSocket sessions.
PROXIMA_JWT_SECRET=

# Google OAuth access token with gmail.send and calendar.events scopes.
GOOGLE_ACCESS_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Slack incoming-webhook endpoint.
SLACK_WEBHOOK_URL=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Pinecone serverless index host and key.
PINECONE_API_KEY=
PINECONE_INDEX_HOST=
PINECONE_NAMESPACE=proxima

# Optional durable distributed queue.
REDIS_URL=redis://127.0.0.1:6379

# Docker sandbox. Network is disabled by default; set bridge only for a consented research task.
PROXIMA_ENABLE_SANDBOX=false
PROXIMA_SANDBOX_IMAGE=node:22-alpine
PROXIMA_SANDBOX_NETWORK=none

# Development-only deterministic fallback. Do not use this for a product demo.
PROXIMA_ALLOW_DEMO_FALLBACK=false

# Social publishing. OAuth redirects must use these externally reachable URLs.
PROXIMA_PUBLIC_APP_URL=http://localhost:3001
PROXIMA_PUBLIC_API_URL=http://localhost:8000
PROXIMA_FRONTEND_CALLBACK_URL=http://localhost:3001/dashboard/integrations
# 32+ random bytes, e.g. `openssl rand -base64 48`; encrypts OAuth tokens at rest.
PROXIMA_TOKEN_ENCRYPTION_KEY=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
