# Next.js server-side proxy target (keep this private; it is not exposed to browser code).
PROXIMA_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Browser WebSocket endpoint. Use wss:// in production.
NEXT_PUBLIC_PROXIMA_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Optional public API URL for components that call the backend directly.
NEXT_PUBLIC_PROXIMA_API_URL=http://localhost:8000
